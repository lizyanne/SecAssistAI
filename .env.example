# ==============================================================================
# SECASSIST - CONFIGURATION TEMPLATE
# ==============================================================================
# This template defines the environment variables required for SecAssist.
# Do NOT store raw production keys directly inside this .env.example file.

# ------------------------------------------------------------------------------
# 1. GOOGLE GEMINI AI CONFIGURATION
# ------------------------------------------------------------------------------
# Required for generating dynamic Executive Summaries, Technical Analyses, 
# Remediation Plans, and Threat Intelligence reasoning.
GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (POSTGRESQL OR SUPABASE)
# ------------------------------------------------------------------------------
# Provide either a single comprehensive connection URI string (highly recommended):
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?sslmode=require
DATABASE_URL=

# OR specify individual database connection credentials:
SQL_HOST=
SQL_PORT=5432
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
